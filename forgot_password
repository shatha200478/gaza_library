session_start();
include '../db.php';

$message = "";

if ($_SERVER["REQUEST_METHOD"] == "POST") {

    $username = mysqli_real_escape_string($conn, $_POST['username']);
    $university = mysqli_real_escape_string($conn, $_POST['university']);

    $check = $conn->query("SELECT * FROM users WHERE username='$username' AND university_id='$university'");

    if ($check && $check->num_rows > 0) {

        $conn->query("
    INSERT INTO password_requests (username, university_id)
    VALUES ('$username', '$university')
");

        $message = "تم إرسال طلب استعادة كلمة المرور بنجاح، يرجى مراجعة مدير النظام.";
    } else {
        $message = "البيانات المدخلة غير موجودة في النظام.";
    }
}
